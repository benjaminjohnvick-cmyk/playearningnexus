{
  "name": "DeveloperFollow",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "User following the developer"
    },
    "developer_id": {
      "type": "string",
      "description": "Business client being followed"
    },
    "notifications_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether to receive notifications about new games"
    }
  },
  "required": [
    "user_id",
    "developer_id"
  ]
}