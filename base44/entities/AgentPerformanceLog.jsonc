{
  "name": "AgentPerformanceLog",
  "type": "object",
  "properties": {
    "agent_name": {
      "type": "string",
      "description": "Name of the AI agent (e.g. churn_predictor, fraud_detection)"
    },
    "action_type": {
      "type": "string",
      "description": "What the agent did (prediction, recommendation, modification, campaign_sent)"
    },
    "target_entity": {
      "type": "string",
      "description": "Entity type affected (User, PPCSurvey, etc.)"
    },
    "target_id": {
      "type": "string",
      "description": "ID of the affected record"
    },
    "input_data": {
      "type": "object",
      "additionalProperties": true,
      "description": "Snapshot of data the agent used to make the decision"
    },
    "output_data": {
      "type": "object",
      "additionalProperties": true,
      "description": "What the agent produced (prediction, recommended action, message sent)"
    },
    "predicted_outcome": {
      "type": "string",
      "description": "What the agent predicted would happen"
    },
    "actual_outcome": {
      "type": "string",
      "description": "What actually happened (filled in later by evaluation function)"
    },
    "outcome_verified": {
      "type": "boolean",
      "default": false
    },
    "outcome_verified_at": {
      "type": "string",
      "format": "date-time"
    },
    "was_correct": {
      "type": "boolean",
      "description": "Whether agent prediction/recommendation was correct"
    },
    "human_review_status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "implemented",
        "skipped"
      ],
      "default": "pending"
    },
    "human_reviewer": {
      "type": "string"
    },
    "human_notes": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "confidence_score": {
      "type": "number",
      "description": "Agent's own confidence 0-100"
    },
    "impact_score": {
      "type": "number",
      "description": "Measured business impact 0-100 (filled post-outcome)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "required": [
    "agent_name",
    "action_type"
  ]
}