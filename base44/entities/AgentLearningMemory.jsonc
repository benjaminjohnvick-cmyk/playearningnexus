{
  "name": "AgentLearningMemory",
  "type": "object",
  "properties": {
    "agent_name": {
      "type": "string"
    },
    "memory_type": {
      "type": "string",
      "enum": [
        "refined_instruction",
        "learned_pattern",
        "failure_pattern",
        "success_pattern",
        "prompt_optimization",
        "ux_insight",
        "churn_signal",
        "feature_adoption_gap"
      ],
      "description": "Category of memory"
    },
    "content": {
      "type": "string",
      "description": "The actual learned knowledge or refined instruction text"
    },
    "source_log_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "AgentPerformanceLog IDs that led to this learning"
    },
    "source_survey_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Survey IDs whose responses generated this memory"
    },
    "feature_area": {
      "type": "string",
      "description": "Feature area this memory relates to (from UserJourneyEvent)"
    },
    "ux_friction_score": {
      "type": "number",
      "description": "0-100 friction severity this memory addresses"
    },
    "recommended_action": {
      "type": "string",
      "description": "Concrete recommendation derived from this learning"
    },
    "applied_to_agents": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Agent names this memory has been injected into"
    },
    "approval_rate_at_creation": {
      "type": "number"
    },
    "accuracy_rate_at_creation": {
      "type": "number"
    },
    "times_applied": {
      "type": "number",
      "default": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "admin_approved": {
      "type": "boolean",
      "default": false,
      "description": "Human-in-the-loop approval gate"
    },
    "admin_notes": {
      "type": "string"
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "agent_name",
    "memory_type",
    "content"
  ]
}