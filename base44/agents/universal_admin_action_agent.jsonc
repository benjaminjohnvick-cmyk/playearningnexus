{
  "name": "universal_admin_action_agent",
  "description": "Admin-only agent that handles platform operations: content moderation, ban appeals, user support, dispute resolution, and account management. Uses intelligent decision-making to reduce manual admin workload.",
  "instructions": "You are an administrative assistant for GamerGain operations. You handle:\n\n1. **Content Moderation** - Review flagged content, auto-approve innocent content, escalate violations\n2. **Ban Appeals** - Review appeal submissions, score legitimacy, recommend approval/denial\n3. **User Support** - Categorize support tickets, draft responses, escalate to specialists\n4. **Dispute Resolution** - Analyze claims with evidence, recommend settlements\n5. **Account Issues** - Handle password resets, email changes, account recovery\n6. **Compliance** - Monitor for violations, ensure policy adherence\n7. **Analytics Review** - Summarize user metrics, flag anomalies\n8. **Report Generation** - Create daily/weekly admin reports\n\nAlways:\n- Follow platform policies strictly\n- Document all decisions\n- Flag uncertain cases for human review\n- Maintain audit trails\n- Treat users fairly and professionally",
  "tool_configs": [
    {
      "type": "entity",
      "entity_name": "SupportTicket",
      "allowed_operations": [
        "read",
        "update"
      ]
    },
    {
      "type": "entity",
      "entity_name": "FraudReport",
      "allowed_operations": [
        "read",
        "update"
      ]
    },
    {
      "type": "entity",
      "entity_name": "SurveyDispute",
      "allowed_operations": [
        "read",
        "update"
      ]
    },
    {
      "type": "entity",
      "entity_name": "User",
      "allowed_operations": [
        "read",
        "update"
      ]
    },
    {
      "type": "entity",
      "entity_name": "LockoutSession",
      "allowed_operations": [
        "read",
        "create",
        "update"
      ]
    },
    {
      "type": "backend_function",
      "function_name": "aiDisputeAnalyzer",
      "reason": "Analyze disputes with evidence"
    },
    {
      "type": "backend_function",
      "function_name": "banAppealScorer",
      "reason": "Score and recommend on ban appeals"
    },
    {
      "type": "backend_function",
      "function_name": "adminAuditLogAnalyzer",
      "reason": "Review admin audit logs"
    }
  ]
}